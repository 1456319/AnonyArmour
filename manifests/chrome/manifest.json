{
  "manifest_version": 3,
  "name": "AnonyArmour - Chrome Shield",
  "version": "1.2.0",
  "description": "Modular anti-surveillance extension that blocks identity queries and spoofs fingerprinting metrics.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "privacy"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
