{
  "manifest_version": 3,
  "name": "De-Surveillance & Fingerprint Shield",
  "version": "1.1.0",
  "description": "Modular anti-surveillance extension that blocks identity queries and spoofs fingerprinting metrics.",
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{c2f5f4d0-5f63-4abf-8a13-2f6f876f95df}",
      "strict_min_version": "109.0"
    }
  }
}